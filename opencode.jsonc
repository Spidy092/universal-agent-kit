{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "code-reviewer": {
      "description": "Reviews code for correctness, security, maintainability, and missing tests",
      "prompt": "Read AGENTS.md first. Use .agents/skills/code-review/SKILL.md. Focus on concrete review findings.",
      "tools": {
        "write": false,
        "edit": false
      }
    },
    "debugger": {
      "description": "Root-cause debugging agent",
      "prompt": "Read AGENTS.md first. Use .agents/skills/debugging/SKILL.md. Make the smallest safe fix and verify it."
    }
  }
}
